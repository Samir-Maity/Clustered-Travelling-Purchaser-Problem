def swap(p, ss):
    t1 = deepcopy(p)
    for i in range(ss.n):
        t1[ss.ss[i][0]], t1[ss.ss[i][1]] = t1[ss.ss[i][1]], t1[ss.ss[i][0]]
        
    return t1    
   
def path_diff(p1, p2):
    #input("wait in path diff")
    x, y = p1, p2
    d = SwapSequence()
    for i in range(NN):
        j = y.index(x[i])
        if i != j:
            d.ss[d.n] = [i, j]
            y[i], y[j] = y[j], y[i]
            d.n += 1
    #print(f"{d.ss[0][1]} and {d.n}")
    #input(" wait in sss")
    return d       

