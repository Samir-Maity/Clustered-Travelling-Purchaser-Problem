def generate_weight_vectors():
    """Generate weight vectors for scalarization in MOEA/D."""
    weights = []
    for i in range(NS):
        w1 = i / (NS - 1)
        weights.append([w1, 1 - w1])
    return weights

def find_neighbors(weights):
    """Find neighbors for each weight vector based on Euclidean distance."""
    neighbors = []
    for i in range(NS):
        dis = [np.linalg.norm(np.array(weights[i]) - np.array(weights[j])) for j in range(NS)]
        neighbor_indices = sorted(range(len(dis)), key=lambda x: dis[x])[:NUM_NEIGHBORS]
        neighbors.append(neighbor_indices)
    return neighbors
def scalarize(objectives, weights):
    """Weighted sum scalarization for MOEA/D."""
    return sum(w * obj for w, obj in zip(weights, objectives))   


def genetic_algorithm_operator(tour):
    """Apply crossover and mutation to generate new tours."""
    # Mutation: Swap two cities in the tour
    if random.random() < MUTATION_RATE:
        i, j = random.sample(range(NUM_CITIES), 2)
        tour[i], tour[j] = tour[j], tour[i]
    return tour 

