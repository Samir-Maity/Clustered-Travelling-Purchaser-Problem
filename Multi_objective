# Function to calculate Euclidean distance
def equ_dis(p, q, w, z):
    val1 = math.pow((w - p), 2)
    val2 = math.pow((z - q), 2)
    return math.sqrt(val1 + val2)

# K-means algorithm

def k_means():
    
    v = 0  # This will control the while loop
    
    # Initialize nod array
    for i in range(0, len(z)):
        nod[i] = i
    
    while v != 1:  # Loop until centroids stop updating
        # Clear the cluster assignments at the start of each iteration
        for j in range(0, cl):
            cluster[j].s.clear()  # Clear the list to remove previous assignments
            cluster[j].lenth = 0  # Reset the length attribute
        
        # Assign points to the nearest cluster
        for i in range(0, len(z)):
            min_dist = 99999
            pos = -1
            for j in range(0, cl):
                # Compute the distance between point i and cluster j's centroid
                value = equ_dis(x[nod[i]], y[nod[i]], cluster[j].cx, cluster[j].cy)
                if value < min_dist:
                    min_dist = value
                    pos = j
            
            # Append the point to the closest cluster's list
            cluster[pos].s.append(nod[i])
            
            cluster[pos].lenth += 1
        
        # Compute new centroids
        convergence = True  # Assume centroids converge unless proven otherwise
        
        for j in range(0, cl):
            s1 = 0
            s2 = 0
            for k in range(0, cluster[j].lenth):
                s1 += x[cluster[j].s[k]]
                s2 += y[cluster[j].s[k]]
            
            if cluster[j].lenth > 0:
                new_cx = s1 / cluster[j].lenth
                new_cy = s2 / cluster[j].lenth
                
                # Check if the centroids have changed
                if cluster[j].cx != new_cx or cluster[j].cy != new_cy:
                    convergence = False  # Centroids are still changing
                
                # Update the centroid values
                cluster[j].cx = new_cx
                cluster[j].cy = new_cy
        
        # If centroids have converged, stop the loop
        if convergence:
            v = 1  # Exit the loop since centroids have stabilized
  ##END of K-Mean algorithm ################
  

