def is_dominated(solution, other_solution):
    """ Check if solution is dominated by other_solution """
    return all(x <= y for x, y in zip(solution, other_solution)) and any(x < y for x, y in zip(solution, other_solution))

def find_pareto_front(solutions):
    pareto_front = []
    for sol in solutions:
        if not any(is_dominated(sol, other) for other in solutions if sol != other):
            pareto_front.append(sol)
    return pareto_front
         
